# OpenAI API Configuration (LiteLLM will use these)
OPENAI_API_KEY="sk-your_openai_api_key"
# AZURE_OPENAI_ENDPOINT="your_azure_openai_endpoint" # Uncomment if using Azure OpenAI
# AZURE_DEPLOYMENT_NAME="your_azure_deployment_name"   # Uncomment if using Azure OpenAI
# OPENAI_API_BASE="your_custom_openai_api_base"      # Uncomment for self-hosted or other OpenAI-compatible APIs

# Google Gemini API Configuration (LiteLLM will use this)
GEMINI_API_KEY="your_gemini_api_key"

# Example for a local HuggingFace model served via an OpenAI-compatible API (e.g., Ollama, vLLM)
# This tells LiteLLM how to access your local model.
# You might need to set custom model names and API bases depending on your local setup.
# For example, if you are using Ollama and have pulled the 'mistral' model:
# LOCAL_HF_MODEL_NAME="ollama/mistral" # This tells LiteLLM to use the 'ollama' provider for 'mistral'
# LOCAL_HF_API_BASE="http://localhost:11434" # Default Ollama API base

# If you have another local model server that's OpenAI compatible:
# LOCAL_HF_MODEL_NAME="custom/my-local-model" # A name you give, LiteLLM might need specific prefix or use it as is
# LOCAL_HF_API_BASE="http://localhost:8000/v1" # Example endpoint for a local server
# LOCAL_HF_API_KEY="EMPTY" # Often local servers don't require an API key, or it can be arbitrary

# Application specific
UPLOAD_FOLDER="app/data" # Default upload folder

# Note: For LiteLLM to pick up Azure OpenAI, GEMINI_API_KEY, etc.,
# ensure they are set in your actual .env file or environment.
# LiteLLM has specific environment variable names it looks for, e.g.,
# AZURE_API_KEY, AZURE_API_BASE, AZURE_API_VERSION, GEMINI_API_KEY.
# The OPENAI_API_KEY is standard.
# For other providers, you might need to set them in code when calling litellm.completion
# or ensure LiteLLM's environment variable conventions are followed.
# The variables above are provided for clarity for our application's config loading.
# We will map these to LiteLLM's expectations or pass them directly.

# For Azure, also ensure these are set if you are using Azure OpenAI directly (not through LiteLLM's auto-detection via env vars)
# or if LiteLLM needs them explicitly for its Azure configuration.
# AZURE_OPENAI_API_KEY="your_azure_api_key" # if different from OPENAI_API_KEY or for clarity
# AZURE_OPENAI_API_VERSION="2023-07-01-preview" # or your specific API version
